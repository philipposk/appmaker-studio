# ── AppMaker frontend environment ──────────────────────────────
# Copy this file to `.env` and fill in the values.
# Create React App only exposes variables prefixed with REACT_APP_.
# These are baked into the static build at BUILD time, not runtime.

# Base URL of the backend API — must include the /api suffix.
#   Local:      http://localhost:8000/api
#   Production: https://api.appmaker.6x7.gr/api   (or /api if same host)
REACT_APP_API_URL=http://localhost:8000/api

# Optional default Groq key compiled into the build.
# NOT recommended for public sites — anyone can read it in the bundle.
# Leave blank and let users enter their own key in Provider Settings.
REACT_APP_GROQ_API_KEY=
