# ── AppMaker backend environment ───────────────────────────────
# Copy this file to `.env` and fill in the values.
# NEVER commit your real .env — it is gitignored for a reason.

# Port the API listens on.
PORT=8000

# development | production
NODE_ENV=development

# MongoDB connection string.
#   Local:  mongodb://localhost:27017/appmaker
#   Atlas:  mongodb+srv://USER:PASS@cluster.xxxx.mongodb.net/appmaker
MONGODB_URI=mongodb://localhost:27017/appmaker

# Secret used to sign JWT auth tokens. Use a long random value.
# Generate one with:  openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# How long issued tokens stay valid (e.g. 7d, 24h).
JWT_EXPIRE=7d

# Optional fallback Groq API key. Leave blank to require users to bring
# their own key from the Provider Settings page (recommended for public
# deployments — user keys live in their browser, never on the server).
GROQ_API_KEY=

# Allowed frontend origin(s) for CORS. Comma-separate multiple.
#   e.g. https://appmaker.6x7.gr,https://www.appmaker.6x7.gr
FRONTEND_URL=http://localhost:3000
